		</xs:complexContent>
	</xs:complexType>
	<xs:simpleType name="NotificationType">
		<xs:annotation>
			<xs:documentation>		
			</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:enumeration value="Email"/>
			<xs:enumeration value="Phone"/>
			<xs:enumeration value="FTP"/>
			<xs:enumeration value="Webservice"/>
			<xs:enumeration value="Chat"/>
			<xs:enumeration value="Text"/>
			<xs:enumeration value="Other"/>
		</xs:restriction>
	</xs:simpleType>
	<!-- Added to 5.0 -->
	<xs:complexType name="ChargeOfferType">
		<xs:sequence>
			<xs:element maxOccurs="unbounded" minOccurs="0" name="Limits" type="LimitsType"/>
			<xs:element name="ChargeOfferItem" type="ChargeOfferItemType"/>
		</xs:sequence>
		<xs:attribute name="Code" use="required">
			<xs:simpleType>
				<xs:restriction base="xs:string">
					<xs:enumeration value="ACCOUNTING">
						<xs:annotation>
							<xs:documentation>Charges related to financial transactions and services provided to tenants. These fees are associated with the processing and management of payments and other financial activities.
							</xs:documentation>
						</xs:annotation>
					</xs:enumeration>
					<xs:enumeration value="ADMIN">
						<xs:annotation>
							<xs:documentation>Administrative fees generally cover the costs associated with preparing the lease, setting up the resident in the property management system, and other logistical aspects of finalizing the lease process. These fees can sometimes include move-in preparation, such as unit inspections.
							</xs:documentation>
						</xs:annotation>
					</xs:enumeration>
					<xs:enumeration value="AMENITY">
						<xs:annotation>
							<xs:documentation>Charges for using shared building amenities, such as fitness centers, swimming pools, clubhouses, rooftop decks, or lounges. These fees help maintain and manage these facilities.
							</xs:documentation>
						</xs:annotation>
					</xs:enumeration>
					<xs:enumeration value="APPLICATION">
						<xs:annotation>
							<xs:documentation>Application fees cover the cost of processing the application, including background checks, credit checks, and verification of income and rental history.
							</xs:documentation>
						</xs:annotation>
					</xs:enumeration>
					<xs:enumeration value="CLEAN">
						<xs:annotation>
							<xs:documentation>Fees for cleaning services after a resident moves out, ensuring the apartment is ready for the next resident. Some leases also have cleaning charges during tenancy if certain services are requested.
							</xs:documentation>
						</xs:annotation>
					</xs:enumeration>
					<xs:enumeration value="DAMAGE">
						<xs:annotation>
							<xs:documentation>Costs to repair any damages to the apartment caused by the resident that go beyond normal wear and tear. These may cover repairs to walls, floors, appliances, or fixtures.
							</xs:documentation>
						</xs:annotation>
					</xs:enumeration>
					<xs:enumeration value="GOVT">
						<xs:annotation>
							<xs:documentation>Charges imposed by a government entity or jurisdiction, for example LA-area SCEP fee, Hawaii GET Tax, or Rent Board Fee.
							</xs:documentation>
						</xs:annotation>
					</xs:enumeration>
					<xs:enumeration value="HOLD">
						<xs:annotation>
							<xs:documentation>A fee to reserve the unit for the applicant, temporarily holding it off the market until the lease begins.
							</xs:documentation>
						</xs:annotation>
					</xs:enumeration>
					<xs:enumeration value="INSURANCE">
						<xs:annotation>
							<xs:documentation>Some properties may require residents to carry renter’s insurance, and the landlord might charge a fee for providing an insurance policy if the resident does not obtain their own. This insurance typically covers resident liability and personal property protection.
							</xs:documentation>
						</xs:annotation>
					</xs:enumeration>
					<xs:enumeration value="KEY">
						<xs:annotation>
							<xs:documentation>Fees and deposits for keys, fobs, access cards, or lock changes. Lost keys may incur additional charges, and some properties have fees for electronic access systems.
							</xs:documentation>
						</xs:annotation>
					</xs:enumeration>
					<xs:enumeration value="LEASE">
						<xs:annotation>
							<xs:documentation>Monthly scheduled rent charges, including any concessions, late rent charges, early payment discounts etc.
							</xs:documentation>
						</xs:annotation>
					</xs:enumeration>
					<xs:enumeration value="LEGAL">
						<xs:annotation>
							<xs:documentation>Charges to cover the landlord’s legal expenses if they need to pursue eviction or other legal actions due to non-compliance with the lease terms.
							</xs:documentation>
						</xs:annotation>
					</xs:enumeration>
					<xs:enumeration value="OTHER">
						<xs:annotation>
							<xs:documentation>Other/miscellaneous fees and charges
							</xs:documentation>
						</xs:annotation>
					</xs:enumeration>
					<xs:enumeration value="PARKING">
						<xs:annotation>
							<xs:documentation>Fees for designated parking spaces, covered parking, garages, or visitor parking permits. Prices vary based on the type of parking offered.
							</xs:documentation>
						</xs:annotation>
					</xs:enumeration>
					<xs:enumeration value="PET">
						<xs:annotation>
							<xs:documentation>These include monthly pet rent, pet deposits, or cleaning fees for residents with pets. Additional charges may apply for damages caused by pets.
							</xs:documentation>
						</xs:annotation>
					</xs:enumeration>
					<xs:enumeration value="SERVICE">
						<xs:annotation>
							<xs:documentation>Broadly cover services like trash collection, pest control, common area maintenance, landscaping, or snow removal.
							</xs:documentation>
						</xs:annotation>
					</xs:enumeration>
					<xs:enumeration value="STORAGE">
						<xs:annotation>
							<xs:documentation>Fees for storage units, bike storage spaces, or other designated storage areas on the property.
							</xs:documentation>
						</xs:annotation>
					</xs:enumeration>
					<xs:enumeration value="TECH">
						<xs:annotation>
							<xs:documentation>Charges for optional internet, cable, or other connectivity services provided by the building. Some apartments bundle these into a technology fee or provide a third-party package option.
							</xs:documentation>
						</xs:annotation>
					</xs:enumeration>
					<xs:enumeration value="TERM">
						<xs:annotation>
							<xs:documentation>Fees for breaking a lease before its expiration date. These may cover lost rent, re-leasing expenses, and sometimes a specific penalty amount.
							</xs:documentation>
						</xs:annotation>
					</xs:enumeration>
					<xs:enumeration value="TRANSFER">
						<xs:annotation>
							<xs:documentation>Fees for residents who wish to transfer to a different unit within the same property. These cover administrative and preparation costs for the new unit.
							</xs:documentation>
						</xs:annotation>
					</xs:enumeration>
					<xs:enumeration value="UPGRADE">
						<xs:annotation>
							<xs:documentation>Non-essential/optional improvements or additions to the unit that the tenant can make. These fees are for tenant-selected upgrades that go beyond the standard offerings.
							</xs:documentation>
						</xs:annotation>
					</xs:enumeration>
					<xs:enumeration value="UTILITY">
						<xs:annotation>
							<xs:documentation>Charges for utilities like electricity, water, gas, and sewer (but not trash – see SERVICE). Some leases include utilities, while others bill usage based on direct consumption.
							</xs:documentation>
						</xs:annotation>
					</xs:enumeration>
					<xs:enumeration value="VIOLATION">
						<xs:annotation>
							<xs:documentation>Charges imposed due to breaches of lease agreements or noncompliance with property rules and regulations. These fees are intended to address and rectify tenant actions that violate the terms of the lease or community standards. Examples include smoking and package service violations. Some violations may be included under the more specific classes instead, for example PET.
							</xs:documentation>
						</xs:annotation>
					</xs:enumeration>
				</xs:restriction>
			</xs:simpleType>
		</xs:attribute>
	</xs:complexType>
	<xs:complexType name="LimitsType">
		<xs:annotation>
			<xs:documentation>Restrict the maximum number or the maximum amount of items that appear in the charge class, for example to restrict the total number of storage spaces, or the maximum monthly pet rent.
			</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="MaximumOccurences" type="xs:integer">
				<xs:annotation>
					<xs:documentation>The maximum number of items in the class, or – if Applies To or Characteristics are specified – the maximum number of items of the specified item types.
					</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="MaximumAmount" type="xs:decimal">
				<xs:annotation>
					<xs:documentation>The maximum total amount of items in the class, or – if Applies To or Characteristics are specified – the maximum number of items of the specified item types.
					</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element maxOccurs="1" minOccurs="0" name="AppliesTo">
				<xs:annotation>
					<xs:documentation>The specific item types (by Internal Code) that this maximum applies to. If omitted, it applies to all internal codes in the class meeting any Characteristic constraints.
					</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:sequence>
						<xs:element maxOccurs="unbounded" minOccurs="0" name="InternalCode"
							type="xs:string">
							<xs:annotation>
								<xs:documentation>The internal code of the specific items that are included in this limit, e.g. PETDOG, PETCAT
								</xs:documentation>
							</xs:annotation>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="Characteristic" type="CharacteristicsType"/>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="CharacteristicsType">
		<xs:annotation>
			<xs:documentation>The specific characteristics of items that are included in this limit. Any characteristics that are not specified are assumed to be allowed any value. If omitted, the limit applies to all characteristics in the class meeting any Applies To constraint. For example, this could be used to place a maximum monetary amount on non-refundable monthly pet charges, without including deposit items.
			</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="ChargeRequirement">
				<xs:annotation>
					<xs:documentation>Included, Mandatory, Situational, Conditional, or Optional
					</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:enumeration value="Included">
							<xs:annotation>
								<xs:documentation>This item is included – there is no additional charge. Typically used for items that are usually chargeable, rather than general amenities.
								</xs:documentation>
							</xs:annotation>
						</xs:enumeration>
						<xs:enumeration value="Mandatory">
							<xs:annotation>
								<xs:documentation>This item will be charged in all circumstances.
								</xs:documentation>
							</xs:annotation>
						</xs:enumeration>
						<xs:enumeration value="Situational">
							<xs:annotation>
								<xs:documentation>This item will be charged in certain situations – for example when damage is caused by pets, early termination, or late fees.
								</xs:documentation>
							</xs:annotation>
						</xs:enumeration>
						<xs:enumeration value="Optional">
							<xs:annotation>
								<xs:documentation>This item is used at the discretion of the resident, for example renting a party room, or guest suite.
								</xs:documentation>
							</xs:annotation>
						</xs:enumeration>
						<xs:enumeration value="Conditional">
							<xs:annotation>
								<xs:documentation>This Charge depends on the presence of another (optional) internal code. If the other code is present, then this conditional Charge is automatically included. 
								</xs:documentation>
							</xs:annotation>
						</xs:enumeration>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element maxOccurs="1" minOccurs="0" name="ConditionalAppliesTo">
				<xs:annotation>
					<xs:documentation>If the Charge Requirement is Conditional, this specifies the internal code(s) of the Charge Offer Item(s) the presence of (or any one of) will trigger the automatic inclusion of this Charge Offer Item
					</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:sequence>
						<xs:element maxOccurs="unbounded" minOccurs="0" name="InternalCode"
							type="xs:string">
							<xs:annotation>
								<xs:documentation>Charge Offer Item internal code
								</xs:documentation>
							</xs:annotation>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="RequirementDescription" type="xs:string">
				<xs:annotation>
					<xs:documentation>Description of the conditions under which situational or optional charges will be applied.
					</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Refundability">
				<xs:annotation>
					<xs:documentation>Determines whether this item is never refunded, expected to be refunded (e.g. a deposit), or possibly refunded (e.g. a hold fee).
					</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:enumeration value="Non-refundable">
							<xs:annotation>
								<xs:documentation>This item is not refundable under any circumstances.
								</xs:documentation>
							</xs:annotation>
						</xs:enumeration>
						<xs:enumeration value="Deposit">
							<xs:annotation>
								<xs:documentation>This item is expected to be refunded providing the terms are not broken, for example a rent security deposit or pet damage deposit.
								</xs:documentation>
							</xs:annotation>
						</xs:enumeration>
						<xs:enumeration value="Refundable">
							<xs:annotation>
								<xs:documentation>This item is not expected to be refunded, but may be (either fully or partially) in some circumstances.
								</xs:documentation>
							</xs:annotation>
						</xs:enumeration>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="RefundabilityMaxType">
				<xs:annotation>
					<xs:documentation>Determines whether the maximum amount refundable is specified as an explicit amount or as a percentage of the amount paid.
					</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:enumeration value="Amount">
							<xs:annotation>
								<xs:documentation>The maximum refund of a fee is specified by an explicit monetary amount.
								</xs:documentation>
							</xs:annotation>
						</xs:enumeration>
						<xs:enumeration value="Percentage">
							<xs:annotation>
								<xs:documentation>The maximum refund of a fee is specified as a percentage of the fee paid.
								</xs:documentation>
							</xs:annotation>
						</xs:enumeration>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="RefundabilityMax" type="xs:decimal">
				<xs:annotation>
					<xs:documentation>The maximum monetary amount (if Refundability Max Type is amount) or percentage (if Refundability Max Type is percentage) of this fee that could be refunded. For percentages, ‘1’ = 100%.
					</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="RefundabilityDescription" type="xs:string">
				<xs:annotation>
					<xs:documentation>Description of the terms that apply to return of deposits or refunds.
					</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element minOccurs="0" name="RefundabilityPerType">
				<xs:annotation>
					<xs:documentation>Where a refundability maximum is specified, and this item Amount Per Type is either Applicant or Person, this attribute specifies whether the refundability max applies to each per-entity (i.e. per applicant/per person) or whether the max applies to the aggregate of all applicants/people.
					</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:enumeration value="Item">
							<xs:annotation>
								<xs:documentation>The charge applies once in each item or occurrence.
								</xs:documentation>
							</xs:annotation>
						</xs:enumeration>
						<xs:enumeration value="Leaseholder">
							<xs:annotation>
								<xs:documentation>The charge will apply for each person applying, or – if the application is successful – each person named on the lease.
								</xs:documentation>
							</xs:annotation>
						</xs:enumeration>
						<xs:enumeration value="Person">
							<xs:annotation>
								<xs:documentation>The charge will apply for each person, for example for each guest in the guest suite, or for each person resident in the unit.
								</xs:documentation>
							</xs:annotation>
						</xs:enumeration>
						<xs:enumeration value="Period">
							<xs:annotation>
								<xs:documentation>The charge applies for each period, the duration of which is separately specified. For example, per day or per quarter.
								</xs:documentation>
							</xs:annotation>
						</xs:enumeration>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="Lifecycle">
				<xs:annotation>
					<xs:documentation>The stage in the lifecycle of the resident’s lease that this item relates to.
					</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:enumeration value="Pre-application">
							<xs:annotation>
								<xs:documentation>Anything prior to application submission.
								</xs:documentation>
							</xs:annotation>
						</xs:enumeration>
						<xs:enumeration value="At Application">
							<xs:annotation>
								<xs:documentation>Application submission.</xs:documentation>
							</xs:annotation>
						</xs:enumeration>
						<xs:enumeration value="Approved Future Resident">
							<xs:annotation>
								<xs:documentation>Application approved, but not yet moving-in.
								</xs:documentation>
							</xs:annotation>
						</xs:enumeration>
						<xs:enumeration value="Move-in">
							<xs:annotation>
								<xs:documentation>Associated specifically with the move-in.
								</xs:documentation>
							</xs:annotation>
						</xs:enumeration>
						<xs:enumeration value="During Term">
							<xs:annotation>
								<xs:documentation>Within the term-of the lease.
								</xs:documentation>
							</xs:annotation>
						</xs:enumeration>
						<xs:enumeration value="Renewal">
							<xs:annotation>
								<xs:documentation>Associated specifically with a renewal.
								</xs:documentation>
							</xs:annotation>
						</xs:enumeration>
						<xs:enumeration value="Move-out">
							<xs:annotation>
								<xs:documentation>Associated specifically with the move-out.
								</xs:documentation>
							</xs:annotation>
						</xs:enumeration>
						<xs:enumeration value="Past Resident">
							<xs:annotation>
								<xs:documentation>Lease now expired and move-out completed.
								</xs:documentation>
							</xs:annotation>
						</xs:enumeration>
						<xs:enumeration value="Transfer">
							<xs:annotation>
								<xs:documentation>Associated with a transfer from one unit to another.
								</xs:documentation>
							</xs:annotation>
						</xs:enumeration>
						<xs:enumeration value="Other">
							<xs:annotation>
								<xs:documentation>Other not in any of the above.
								</xs:documentation>
							</xs:annotation>
						</xs:enumeration>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="PaymentFrequency">
				<xs:annotation>
					<xs:documentation>The frequency on which the amounts specified in this item will be payable.
					</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:enumeration value="One-time">
							<xs:annotation>
								<xs:documentation>Paid only once.
								</xs:documentation>
							</xs:annotation>
						</xs:enumeration>
						<xs:enumeration value="Per-occurrence">
							<xs:annotation>
								<xs:documentation>Paid each time an item is used or an event takes place.
								</xs:documentation>
							</xs:annotation>
						</xs:enumeration>
						<xs:enumeration value="Hourly">
							<xs:annotation>
								<xs:documentation>Paid per hour.
								</xs:documentation>
							</xs:annotation>
						</xs:enumeration>
						<xs:enumeration value="24h">
							<xs:annotation>
								<xs:documentation>Paid once in each 24 hour period (e.g. daily or nightly).
								</xs:documentation>
							</xs:annotation>
						</xs:enumeration>
						<xs:enumeration value="Weekly">
							<xs:annotation>
								<xs:documentation>Paid every week.
								</xs:documentation>
							</xs:annotation>
						</xs:enumeration>
						<xs:enumeration value="Bi-weekly">
							<xs:annotation>
								<xs:documentation>Paid every two weeks.
								</xs:documentation>
							</xs:annotation>
						</xs:enumeration>
						<xs:enumeration value="Monthly">
							<xs:annotation>
								<xs:documentation>Paid every month.
								</xs:documentation>
							</xs:annotation>
						</xs:enumeration>
						<xs:enumeration value="Bi-monthly">
							<xs:annotation>
								<xs:documentation>Paid every two months.
								</xs:documentation>
							</xs:annotation>
						</xs:enumeration>
						<xs:enumeration value="Quarterly">
							<xs:annotation>
								<xs:documentation>Paid every quarter.
								</xs:documentation>
							</xs:annotation>
						</xs:enumeration>
						<xs:enumeration value="Triannually">
							<xs:annotation>
								<xs:documentation>Paid three times per year.
								</xs:documentation>
							</xs:annotation>
						</xs:enumeration>
						<xs:enumeration value="Semi-annually">
							<xs:annotation>
								<xs:documentation>Paid twice per year.
								</xs:documentation>
							</xs:annotation>
						</xs:enumeration>
						<xs:enumeration value="Annually">
							<xs:annotation>
								<xs:documentation>Paid once per year.
								</xs:documentation>
							</xs:annotation>
						</xs:enumeration>
						<xs:enumeration value="Other">
							<xs:annotation>
								<xs:documentation>Some other payment frequency – see description.
								</xs:documentation>
							</xs:annotation>
						</xs:enumeration>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="ChargeOfferItemType">
		<xs:sequence>
			<xs:element name="Name" type="xs:string">
				<xs:annotation>
					<xs:documentation>Short name indicating what the charge is for, using the operator’s preferred customer-facing language.
					</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Description" type="xs:string">
				<xs:annotation>
					<xs:documentation>Description of the charge explaining what the charge is for using the operator’s preferred customer-facing language, including what the resident gets for the charge, or why they are being charged. This can also include an explanation of fees that are variable (e.g. what the variability depends upon).
					</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Group" type="xs:string">
				<xs:annotation>
					<xs:documentation>In some cases, and operator may have a preferred grouping of fees. When this is the case, this preference should be provided here using the customer-facing name of the group under which this fee would preferably be listed.
					</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Characteristics" type="CharacteristicsType">
				<xs:annotation>
					<xs:documentation>A set of additional characteristics (or metadata) about the charge that can be used to make it easier for the resident to see specific charges and to allow pricing calculators to treat each charge appropriately.
					</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ItemMinimumOccurrences" type="xs:integer">
				<xs:annotation>
					<xs:documentation>If this item is subject to a minimum, it should be specified here. </xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ItemMaximumOccurrences" type="xs:integer">
				<xs:annotation>
					<xs:documentation>If this item is subject to a maximum, it should be specified here. This can be used to limit items to one, or a specific number (e.g. pet dogs might be limited to a maximum of 2). If omitted, it is assumed that there is no limit on the number of individual items of this type that can be added. If class level limits are also specified, then the lowed of the two maximums is used.
					</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="AmountBasis">
				<xs:annotation>
					<xs:documentation>Explicit Amount, Percentage Of, Stepped, or Within Range
					</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:enumeration value="Explicit Amount">
							<xs:annotation>
								<xs:documentation>The amount is specified as an explicit fixed monetary amount.
								</xs:documentation>
							</xs:annotation>
						</xs:enumeration>
						<xs:enumeration value="Percentage Of">
							<xs:annotation>
								<xs:documentation>The amount is calculated as a specified percentage of another Charge Offer amount.
								</xs:documentation>
							</xs:annotation>
						</xs:enumeration>
						<xs:enumeration value="Within Range">
							<xs:annotation>
								<xs:documentation>The amount will lie within a specified range of monetary amounts.
								</xs:documentation>
							</xs:annotation>
						</xs:enumeration>
						<xs:enumeration value="Stepped">
							<xs:annotation>
								<xs:documentation>The amount has specific stepped pricing for the first occurrence of the item and each subsequent occurrence.
								</xs:documentation>
							</xs:annotation>
						</xs:enumeration>
						<xs:enumeration value="Variable">
							<xs:annotation>
								<xs:documentation>The amount of the fee varies depending on some other factors, for example electricity usage.
								</xs:documentation>
							</xs:annotation>
						</xs:enumeration>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="PercentageOfCode" type="xs:string">
				<xs:annotation>
					<xs:documentation>If Amount Basis is Percentage Of, the Internal Code that this Item is calculated as a percentage of.
					</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="AmountPerType">
				<xs:annotation>
					<xs:documentation>Specifies what triggers a repeat of this charge. For example, per Unit would mean the charge is only incurred once per unit (for example, ‘monthly rent’), whereas per Person would indicate the charge is repeated for each Person using an item or taking part in an event (for example ‘overnight stay in guest suite’).
					</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:enumeration value="Item">
							<xs:annotation>
								<xs:documentation>The charge applies once in each item or occurrence.
								</xs:documentation>
							</xs:annotation>
						</xs:enumeration>
						<xs:enumeration value="Leaseholder">
							<xs:annotation>
								<xs:documentation>The charge will apply for each person applying, or – if the application is successful – each person named on the lease.
								</xs:documentation>
							</xs:annotation>
						</xs:enumeration>
						<xs:enumeration value="Person">
							<xs:annotation>
								<xs:documentation>The charge will apply for each person, for example for each guest in the guest suite, or for each person resident in the unit.
								</xs:documentation>
							</xs:annotation>
						</xs:enumeration>
						<xs:enumeration value="Period">
							<xs:annotation>
								<xs:documentation>The charge applies for each period, the duration of which is separately specified. For example, per day or per quarter.
								</xs:documentation>
							</xs:annotation>
						</xs:enumeration>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="AmountPerPeriod" type="xs:string">
				<xs:annotation>
					<xs:documentation>For fees that have an Amount Per Type of Period, what is the duration of each period.
					</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ApplicableToAffordableUnits">
				<xs:annotation>
					<xs:documentation>Indicates whether or not this specific fee applies to units that are identified as affordable. It may be omitted if there are no affordable units I the scope.
					</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ChargeOfferAmount" type="ChargeOfferAmountType" maxOccurs="unbounded"
				minOccurs="0"/>
		</xs:sequence>
		<xs:attribute name="InternalCode" type="xs:string">
			<xs:annotation>
				<xs:documentation>The Internal Code, specific to each data publisher.</xs:documentation>
			</xs:annotation>
		</xs:attribute>
	</xs:complexType>
	<xs:complexType name="ParkingOfferItemType">
		<xs:complexContent>
			<xs:extension base="ChargeOfferItemType">
				<xs:sequence>
					<xs:element name="StructureType">
						<xs:annotation>
							<xs:documentation>Information about the structure that contains the parking.
							</xs:documentation>
						</xs:annotation>
						<xs:simpleType>
							<xs:restriction base="xs:string">
								<xs:enumeration value="Surface Lot">
									<xs:annotation>
										<xs:documentation>Uncovered parking, typically at ground level.
										</xs:documentation>
									</xs:annotation>
								</xs:enumeration>
								<xs:enumeration value="Garage Lot">
									<xs:annotation>
										<xs:documentation>Parking within a parking structure, usually comprising multiple levels with most or all covered.
										</xs:documentation>
									</xs:annotation>
								</xs:enumeration>
								<xs:enumeration value="Covered Lot">
									<xs:annotation>
										<xs:documentation>Parking that is open-sided but that has cover above.
										</xs:documentation>
									</xs:annotation>
								</xs:enumeration>
								<xs:enumeration value="Street">
									<xs:annotation>
										<xs:documentation>Parking is on the street.
										</xs:documentation>
									</xs:annotation>
								</xs:enumeration>
								<xs:enumeration value="Other"/>
								<xs:enumeration value="Garage (attached)">
									<xs:annotation>
										<xs:documentation>Parking is in a private garage attached to the unit.
										</xs:documentation>
									</xs:annotation>
								</xs:enumeration>
								<xs:enumeration value="Garage (detached)">
									<xs:annotation>
										<xs:documentation>Parking is in a private garage that is separated from the unit.
										</xs:documentation>
									</xs:annotation>
								</xs:enumeration>
								<xs:enumeration value="None">
									<xs:annotation>
										<xs:documentation>No parking is available.
										</xs:documentation>
									</xs:annotation>
								</xs:enumeration>
							</xs:restriction>
						</xs:simpleType>
					</xs:element>
					<xs:element name="SizeType">
						<xs:annotation>
							<xs:documentation>Describes the general size of each parking space by reference to the kind of vehicle it is designed to accommodate.
							</xs:documentation>
						</xs:annotation>
						<xs:simpleType>
							<xs:restriction base="xs:string">
								<xs:enumeration value="Motorcycle">
									<xs:annotation>
										<xs:documentation>Suitably sized for a motorcycle.
										</xs:documentation>
									</xs:annotation>
								</xs:enumeration>
								<xs:enumeration value="Compact">
									<xs:annotation>
										<xs:documentation>Suitably sized for a compact car.
										</xs:documentation>
									</xs:annotation>
								</xs:enumeration>
								<xs:enumeration value="Car">
									<xs:annotation>
										<xs:documentation>Suitably sized for a car.
										</xs:documentation>
									</xs:annotation>
								</xs:enumeration>
								<xs:enumeration value="Extended (RV/Boat)">
									<xs:annotation>
										<xs:documentation>Suitably sized for an RV, boat or similar
										</xs:documentation>
									</xs:annotation>
								</xs:enumeration>
								<xs:enumeration value="Other"/>
							</xs:restriction>
						</xs:simpleType>
					</xs:element>
					<xs:element name="RegularSpace">
						<xs:annotation>
							<xs:documentation>Specifies whether regular parking (i.e. not enhanced with EV or handicapped access) is available, and – if so – whether it is also reservable.
							</xs:documentation>
						</xs:annotation>
						<xs:simpleType>
							<xs:restriction base="xs:string">
								<xs:enumeration value="Available">
									<xs:annotation>
										<xs:documentation>This item type is available, but not reservable.
										</xs:documentation>
									</xs:annotation>
								</xs:enumeration>
								<xs:enumeration value="Reservable">
									<xs:annotation>
										<xs:documentation>This item type is available and reservable. This indicates that you are entitled to use any items of the specified type, and this is guaranteed.
										</xs:documentation>
									</xs:annotation>
								</xs:enumeration>
								<xs:enumeration value="None">
									<xs:annotation>
										<xs:documentation>This item type is not available.
										</xs:documentation>
									</xs:annotation>
								</xs:enumeration>
							</xs:restriction>
						</xs:simpleType>
					</xs:element>
					<xs:element name="Handicapped">
						<xs:annotation>
							<xs:documentation>Specifies whether handicapped parking is available, and – if so – whether it is also reservable.
							</xs:documentation>
						</xs:annotation>
						<xs:simpleType>
							<xs:restriction base="xs:string">
								<xs:enumeration value="Available">
									<xs:annotation>
										<xs:documentation>This item type is available, but not reservable.
										</xs:documentation>
									</xs:annotation>
								</xs:enumeration>
								<xs:enumeration value="Reservable">
									<xs:annotation>
										<xs:documentation>This item type is available and reservable. This indicates that you are entitled to use any items of the specified type, and this is guaranteed.
										</xs:documentation>
									</xs:annotation>
								</xs:enumeration>
								<xs:enumeration value="None">
									<xs:annotation>
										<xs:documentation>This item type is not available.
										</xs:documentation>
									</xs:annotation>
								</xs:enumeration>
							</xs:restriction>
						</xs:simpleType>
					</xs:element>
					<xs:element name="Electric">
						<xs:annotation>
							<xs:documentation>Specifies whether parking space with electric vehicle charging points are available, and – if so – whether they are also reservable.
							</xs:documentation>
						</xs:annotation>
						<xs:simpleType>
							<xs:restriction base="xs:string">
								<xs:enumeration value="Available">
									<xs:annotation>
										<xs:documentation>This item type is available, but not reservable.
										</xs:documentation>
									</xs:annotation>
								</xs:enumeration>
								<xs:enumeration value="Reservable">
									<xs:annotation>
										<xs:documentation>This item type is available and reservable. This indicates that you are entitled to use any items of the specified type, and this is guaranteed.
										</xs:documentation>
									</xs:annotation>
								</xs:enumeration>
								<xs:enumeration value="None">
									<xs:annotation>
										<xs:documentation>This item type is not available.
										</xs:documentation>
									</xs:annotation>
								</xs:enumeration>
							</xs:restriction>
						</xs:simpleType>
					</xs:element>
					<xs:element name="SpaceDescription" type="xs:string">
						<xs:annotation>
							<xs:documentation>A narrative description of the space, include information about the mix of different types (e.g. “50 spaces in the surface lot, including 5 designated handicapped spaces, and 10 EV charging spaces”
							</xs:documentation>
						</xs:annotation>
					</xs:element>
				</xs:sequence>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<xs:complexType name="StorageOfferItemType">
		<xs:complexContent>
			<xs:extension base="ChargeOfferItemType">
				<xs:sequence>
					<xs:element name="StorageType">
						<xs:simpleType>
							<xs:restriction base="xs:string">
								<xs:enumeration value="Bike">
									<xs:annotation>
										<xs:documentation>Storage for one bike.
										</xs:documentation>
									</xs:annotation>
								</xs:enumeration>
								<xs:enumeration value="Closet">
									<xs:annotation>
										<xs:documentation>A tall cupboard or wardrobe with a door.
										</xs:documentation>
									</xs:annotation>
								</xs:enumeration>
								<xs:enumeration value="Locker">
									<xs:annotation>
										<xs:documentation>A small lockable cupboard or compartment attached to the wall or floor.
										</xs:documentation>
									</xs:annotation>
								</xs:enumeration>
								<xs:enumeration value="Other"/>
							</xs:restriction>
						</xs:simpleType>
					</xs:element>
					<xs:element name="StorageUoM">
						<xs:annotation>
							<xs:documentation>The units of measurement used for the dimensions that follow
							</xs:documentation>
						</xs:annotation>
						<xs:simpleType>
							<xs:restriction base="xs:string">
								<xs:enumeration value="Inch">
									<xs:annotation>
										<xs:documentation>Measurement specified in inches.
										</xs:documentation>
									</xs:annotation>
								</xs:enumeration>
								<xs:enumeration value="Foot">
									<xs:annotation>
										<xs:documentation>Measurement specified in feet.
										</xs:documentation>
									</xs:annotation>
								</xs:enumeration>
								<xs:enumeration value="Yard">
									<xs:annotation>
										<xs:documentation>Measurement specified in yards.
										</xs:documentation>
									</xs:annotation>
								</xs:enumeration>
								<xs:enumeration value="Meter">
									<xs:annotation>
										<xs:documentation>Measurement specified in meters.
										</xs:documentation>
									</xs:annotation>
								</xs:enumeration>
							</xs:restriction>
						</xs:simpleType>
					</xs:element>
					<xs:element name="Height" type="xs:decimal">
						<xs:annotation>
							<xs:documentation>The internal height of the storage space.
							</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="Width" type="xs:decimal">
						<xs:annotation>
							<xs:documentation>The internal width of the storage space.
							</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="Length" type="xs:decimal">
						<xs:annotation>
							<xs:documentation>The internal length of the storage space.
							</xs:documentation>
						</xs:annotation>
					</xs:element>
				</xs:sequence>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<xs:complexType name="PetOfferItemType">
		<xs:complexContent>
			<xs:extension base="ChargeOfferItemType">
				<xs:sequence>
					<xs:element name="Allowed">
						<xs:annotation>
							<xs:documentation>Indicates whether the specified type of pet (or all pets if no type is specified) are allowed.
							</xs:documentation>
						</xs:annotation>
						<xs:simpleType>
							<xs:restriction base="xs:string">
								<xs:enumeration value="Yes"/>
								<xs:enumeration value="No"/>
							</xs:restriction>
						</xs:simpleType>
					</xs:element>
					<xs:element name="PetBreedorType" type="xs:string">
						<xs:annotation>
							<xs:documentation>The breed (e.g. Airedale Terrier) or type of pet (e.g. Snake) that this item applies to.
							</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="MaximumSize" type="xs:string">
						<xs:annotation>
							<xs:documentation>Describes the maximum size of the pet.
							</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="MaximumWeight" type="xs:string">
						<xs:annotation>
							<xs:documentation>Describes the maximum weight of the pet.
							</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="PetCare">
						<xs:annotation>
							<xs:documentation>Indicates whether pet care is available at the property.
							</xs:documentation>
						</xs:annotation>
						<xs:simpleType>
							<xs:restriction base="xs:string">
								<xs:enumeration value="Yes"/>
								<xs:enumeration value="No"/>
							</xs:restriction>
						</xs:simpleType>
					</xs:element>
				</xs:sequence>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<xs:complexType name="ChargeOfferAmountType">
		<xs:sequence>
			<xs:element name="Amounts" type="xs:decimal" maxOccurs="unbounded" minOccurs="0">
				<xs:annotation>
					<xs:documentation>If the Amount Basis is Fixed Amount, the list contains one specific amount.
						
						If the Amount Basis is Within Range, the list contains two amounts, the first being the lowest amount in the range and the second being the highest amount in the range.
						
						If the Amount Basis is Stepped, the list contains the amount for each subsequent item – i.e. the first amount is the price for the first occurrence, the second amount is for the second occurrence and so on. If there is no maximum number of occurrences, or if the maximum is greater than the number of amounts in the list, the last amount will be used for subsequent occurrences.
						
						Negative amounts indicate credits to the customer account (e.g. concessions). Positive amounts indicate debits (i.e. charges).
					</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Percentage" type="xs:decimal">
				<xs:annotation>
					<xs:documentation>If the Amount Basis is Percentage Of, the percentage.  Negative percentages indicate credits to the customer account (e.g. concessions). Positive percentages indicate debits (i.e. charges).
					</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="TermBasis">
				<xs:annotation>
					<xs:documentation>Whole Lease or Specific Term.
					</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:enumeration value="Whole Lease">
							<xs:annotation>
								<xs:documentation>The period for which the offer applies is the same as the term of the lease.
								</xs:documentation>
							</xs:annotation>
						</xs:enumeration>
						<xs:enumeration value="Specific Term">
							<xs:annotation>
								<xs:documentation>The period for which the offer applies is expressed as a duration (in months) and a start offset (in months) from the start of the lease.
								</xs:documentation>
							</xs:annotation>
						</xs:enumeration>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="StartTermEarliest" type="xs:date">
				<xs:annotation>
					<xs:documentation>If Term Basis is Specific Term, the start date of the specific term, or the earliest date in a range that the Specific Term start date lies. If omitted, any Specific Term start date preceding the Start Term Latest qualifies for this offer.
					</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="StartTermLatest" type="xs:date">
				<xs:annotation>
					<xs:documentation>If Term Basis is Specific Term, the latest date in a range that the Specific Term start date lies. If omitted, the Specific Term can start any time after the given Start Term Earliest. If the same as the Start Term Earliest date, then that is the only Specific Term start date on which this Charge Offer Amount applies.
					</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Duration" type="xs:integer">
				<xs:annotation>
					<xs:documentation>The number of periods committed to, where the duration of each period is specified in the corresponding Charge Offer Item’s Payment Frequency.
					</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Estimate" type="xs:boolean">
				<xs:annotation>
					<xs:documentation>If true, this amount is an estimate, and the actual amount charged could therefore be different.
					</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="EstimationBasis" type="xs:string">
				<xs:annotation>
					<xs:documentation>For estimated amounts, this narratively describes the basis of the estimation, for example utility company estimate, or average for the area.
					</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
</xs:schema>
